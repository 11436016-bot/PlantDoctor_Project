<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    tools:context=".HomeActivity">

    <ImageView
        android:id="@+id/img_doctor_full"
        android:layout_width="372dp"
        android:layout_height="661dp"
        android:scaleType="fitCenter"
        android:src="@drawable/doctor"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.41"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.3" />

    <Button
        android:id="@+id/btn_settings"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:text="個人設定"
        android:textColor="#FFFFFF"
        android:textSize="25sp"
        android:paddingHorizontal="20dp"
        android:background="@drawable/bg_purple_button"
        app:backgroundTint="@null"
        app:layout_constraintTop_toTopOf="@+id/img_doctor_full"
        app:layout_constraintStart_toStartOf="@+id/img_doctor_full"
        android:layout_marginTop="40dp"
        android:layout_marginStart="15dp" />

    <Button
        android:id="@+id/btn_diagnose"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:text="診斷植物"
        android:textColor="#FFFFFF"
        android:textSize="25sp"
        android:paddingHorizontal="20dp"
        android:background="@drawable/bg_purple_button"
        app:backgroundTint="@null"
        app:layout_constraintBottom_toBottomOf="@+id/img_doctor_full"
        app:layout_constraintStart_toStartOf="@+id/img_doctor_full"
        android:layout_marginBottom="40dp"
        android:layout_marginStart="15dp" />

    <Button
        android:id="@+id/btn_history"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:text="查詢病例"
        android:textColor="#FFFFFF"
        android:textSize="25sp"
        android:paddingHorizontal="20dp"
        android:background="@drawable/bg_purple_button"
        app:backgroundTint="@null"
        app:layout_constraintBottom_toBottomOf="@+id/img_doctor_full"
        app:layout_constraintEnd_toEndOf="@+id/img_doctor_full"
        android:layout_marginBottom="40dp"
        android:layout_marginEnd="15dp" />

</androidx.constraintlayout.widget.ConstraintLayout>